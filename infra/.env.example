# mbgc infra config — copy to infra/.env and fill in values
# Run `make setup-infra` to provision infra and sync all secrets to GitHub.
# This file is safe to commit. infra/.env is gitignored.

# Your root domain (e.g. example.com — no protocol, no trailing slash)
DOMAIN=

# GCP console → select your project → project ID shown in the header
# https://console.cloud.google.com/
GCP_PROJECT_ID=

# Supabase dashboard → your project → Settings → General → Reference ID
# https://supabase.com/dashboard/project/_/settings/general
SUPABASE_PROJECT_REF=

# Supabase → Account → Access Tokens → Generate new token
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Supabase dashboard → Storage → S3 Connection → Session token (access key ID)
# https://supabase.com/dashboard/project/_/storage/buckets
S3_ACCESS_KEY_ID=

# Supabase dashboard → Storage → S3 Connection → Session token (secret access key)
S3_SECRET_ACCESS_KEY=

# Cloudflare dashboard → your domain → Overview → Account ID (right sidebar)
# https://dash.cloudflare.com/
CF_ACCOUNT_ID=

# Cloudflare → My Profile → API Tokens → Create Token
# Required scopes: Zone:Read, Zone:Edit, Pages:Edit, DNS:Edit
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Cloudflare dashboard → your domain → Overview → Zone ID (right sidebar)
CLOUDFLARE_ZONE_ID=

# Supabase prod project → Settings → Database → Connection string → URI (port 5432, session pooler)
# https://supabase.com/dashboard/project/_/settings/database
API_DATABASE_URL=

# Supabase prod project → Settings → API → Project URL
# https://supabase.com/dashboard/project/_/settings/api
API_SUPABASE_URL=

# Supabase prod project → Settings → API → API keys → service_role → Reveal
API_SUPABASE_SERVICE_ROLE_KEY=

# Your prod frontend URL — used for CORS (e.g. https://example.com)
API_ALLOWED_ORIGIN=

# Same four fields from your dev Supabase project
DEV_API_DATABASE_URL=
DEV_API_SUPABASE_URL=
DEV_API_SUPABASE_SERVICE_ROLE_KEY=
DEV_API_ALLOWED_ORIGIN=

# Dev admin seed — same as SEED_ADMIN_* in services/api/.env
# Optional: dev Cloud Run creates this user on first boot if set.
DEV_API_SEED_ADMIN_EMAIL=
DEV_API_SEED_ADMIN_PASSWORD=
DEV_API_SEED_ADMIN_USERNAME=
