# mbgc infra config — copy to infra/.env and fill in secrets
# Run `bash scripts/bootstrap.sh` to provision infra and sync all values to GitHub.
# This file is safe to commit. infra/.env is gitignored.

# ── Project ───────────────────────────────────────────────────────────────────
DOMAIN=lumedina.dev
GCP_PROJECT_ID=myboardgamecollection-494214

# ── Supabase (prod project) ───────────────────────────────────────────────────
SUPABASE_PROJECT_REF=mlltpfszhtxhphoaeydh
SUPABASE_ACCESS_TOKEN=        # app.supabase.com → Account → Access Tokens
S3_ACCESS_KEY_ID=             # Supabase dashboard → Storage → S3 Connection
S3_SECRET_ACCESS_KEY=

# ── Cloudflare ────────────────────────────────────────────────────────────────
CF_ACCOUNT_ID=b54fbd0d522b22fc747619b57608bb72
CLOUDFLARE_API_TOKEN=         # Cloudflare dashboard → My Profile → API Tokens (Zone:Edit + Pages:Edit + DNS:Edit)
CLOUDFLARE_ZONE_ID=           # Cloudflare dashboard → your domain → Overview → Zone ID (right sidebar)

# ── Prod API ──────────────────────────────────────────────────────────────────
# Supabase prod dashboard → Settings → Database → URI (port 5432, session pooler)
API_DATABASE_URL=
# Supabase prod dashboard → Settings → API → Project URL
API_SUPABASE_URL=https://mlltpfszhtxhphoaeydh.supabase.co
# Supabase prod dashboard → Settings → API Keys → Legacy tab → service_role → Reveal
API_SUPABASE_SERVICE_ROLE_KEY=
# Your prod frontend URL (used for CORS)
API_ALLOWED_ORIGIN=https://lumedina.dev

# ── Dev API ───────────────────────────────────────────────────────────────────
# Same fields, from your dev Supabase project
DEV_API_DATABASE_URL=
DEV_API_SUPABASE_URL=
DEV_API_SUPABASE_SERVICE_ROLE_KEY=
DEV_API_ALLOWED_ORIGIN=*
