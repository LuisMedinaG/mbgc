# Game service — copy to .env and fill in values
PORT=8002

# Required: Supabase Postgres transaction pooler connection string
# From: Supabase Dashboard → Settings → Database → Connection string → URI
# Format: postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Directory for player aid file uploads (default: data)
DATA_DIR=data/uploads
