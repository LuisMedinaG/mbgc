# ── Server ──────────────────────────────────────────────────────
PORT=8080
ALLOWED_ORIGIN=http://localhost:5173

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=http://127.0.0.1:54321
# Service role key — from `supabase status` (local) or dashboard → Settings → API (prod)
SUPABASE_SERVICE_ROLE_KEY=
# Legacy HS256 secret — leave empty for JWKS-only ES256/RS256 (recommended)
SUPABASE_JWT_SECRET=

# ── Admin seed ───────────────────────────────────────────────────
# If set, the API creates this admin user on first boot (idempotent).
# Safe to leave set permanently — does nothing once the user exists.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# ── BGG importer ─────────────────────────────────────────────────
BGG_TOKEN=
BGG_COOKIE=
SYNC_LIMIT_USER=3
SYNC_LIMIT_ADMIN=20

# ── Acai ─────────────────────────────────────────────────────────
ACAI_API_TOKEN=
