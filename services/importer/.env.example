# Importer service — copy to .env and fill in values
PORT=8003

# Required: Supabase Postgres transaction pooler connection string
# From: Supabase Dashboard → Settings → Database → Connection string → URI
DATABASE_URL=

# Required: game service internal URL
GAME_SERVICE_URL=http://localhost:8002

# Optional: BGG credentials for sync (neither required, but sync disabled without them)
BGG_TOKEN=
BGG_COOKIE=

# Daily sync rate limits (defaults shown)
SYNC_LIMIT_USER=3
SYNC_LIMIT_ADMIN=20
