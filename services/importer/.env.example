# Importer service — copy to .env and fill in values
PORT=8003

# Required: Postgres connection string
#   Local (supabase start):
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
#   Remote (session pooler, port 5432 — use for migrations):
# DATABASE_URL=postgresql://postgres.mlltpfszhtxhphoaeydh:[password]@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# Required: game service internal URL
GAME_SERVICE_URL=http://localhost:8002

# Optional: BGG credentials for sync (sync is disabled without these)
BGG_TOKEN=
BGG_COOKIE=

# Daily BGG sync rate limits (defaults shown)
SYNC_LIMIT_USER=3
SYNC_LIMIT_ADMIN=20
