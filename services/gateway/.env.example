# Gateway — copy to .env and fill in values
PORT=8000

# Required: From Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=

# Internal service URLs (local dev defaults)
AUTH_SERVICE_URL=http://localhost:8001
GAME_SERVICE_URL=http://localhost:8002
IMPORTER_SERVICE_URL=http://localhost:8003

# CORS allowed origin (Vite dev server)
ALLOWED_ORIGIN=http://localhost:5173
