# Gateway — copy to .env and fill in values
PORT=8000

# Required: Supabase project URL. The gateway derives the JWKS endpoint from
# this and verifies access tokens with the project's public signing keys (ES256).
#   Local:  http://127.0.0.1:54321          (supabase start)
#   Remote: https://mlltpfszhtxhphoaeydh.supabase.co
# Get it: supabase projects list
SUPABASE_URL=http://127.0.0.1:54321

# Optional (legacy HS256): only set this to accept tokens minted before the
# project migrated to JWT signing keys. Leave empty for a JWKS-only setup.
# Dashboard → Settings → JWT Keys → Legacy JWT Secret → Reveal
SUPABASE_JWT_SECRET=

# Internal service URLs — local dev defaults
AUTH_SERVICE_URL=http://localhost:8001
GAME_SERVICE_URL=http://localhost:8002
IMPORTER_SERVICE_URL=http://localhost:8003

# CORS allowed origin (Vite dev server)
ALLOWED_ORIGIN=http://localhost:5173
